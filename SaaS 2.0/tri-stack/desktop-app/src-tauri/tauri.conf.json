{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SaaS 2.0 Platform",
  "version": "0.1.0",
  "identifier": "com.saas2.platform",
  "build": {
    "frontendDist": "../../web-dashboard/out"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "SaaS 2.0 Platform",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
